# Copiez ce fichier en .env et remplissez les valeurs

# Base de données MySQL (choisissez des mots de passe forts)
DB_PASSWORD=choisir-un-mot-de-passe-fort
DB_ROOT_PASSWORD=choisir-un-mot-de-passe-root-fort

# API Gemini (obligatoire)
GEMINI_API_KEY=votre-cle-api-gemini-ici

# Mode bêta — laisser vide pour ouvrir l'inscription à tous
BETA_CODE_INVITATION=

# AWS S3 — laisser vide pour utiliser le stockage local
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
# Sur EC2 avec rôle IAM : laisser vide (credentials automatiques)
# En local ou hors EC2 : renseigner les clés d'un utilisateur IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
