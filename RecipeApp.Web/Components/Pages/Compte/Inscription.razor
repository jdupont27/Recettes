@page "/compte/inscription"
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Configuration
@using RecipeApp.Infrastructure.Identity
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<PageTitle>Inscription</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">Créer un compte</h2>

                @if (_erreurs.Count > 0)
                {
                    <div class="alert alert-danger">
                        <ul class="mb-0">
                            @foreach (var erreur in _erreurs)
                            {
                                <li>@erreur</li>
                            }
                        </ul>
                    </div>
                }

                <EditForm method="post" Model="Modele" OnValidSubmit="SInscrire" FormName="inscription">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Nom d'affichage</label>
                        <InputText @bind-Value="Modele!.NomAffichage" class="form-control" />
                        <ValidationMessage For="() => Modele!.NomAffichage" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Adresse e-mail</label>
                        <InputText @bind-Value="Modele!.Email" class="form-control" type="email" />
                        <ValidationMessage For="() => Modele!.Email" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mot de passe</label>
                        <InputText @bind-Value="Modele!.MotDePasse" class="form-control" type="password" />
                        <ValidationMessage For="() => Modele!.MotDePasse" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirmer le mot de passe</label>
                        <InputText @bind-Value="Modele!.Confirmation" class="form-control" type="password" />
                        <ValidationMessage For="() => Modele!.Confirmation" />
                    </div>

                    @if (!string.IsNullOrEmpty(Configuration["Beta:CodeInvitation"]))
                    {
                        <div class="mb-3">
                            <label class="form-label">Code d'invitation</label>
                            <InputText @bind-Value="Modele!.CodeInvitation" class="form-control" placeholder="Entrez votre code d'invitation" />
                            <div class="form-text">Ce site est en accès limité. Un code d'invitation est requis.</div>
                        </div>
                    }

                    <button type="submit" class="btn btn-success w-100">Créer mon compte</button>
                </EditForm>

                <hr />
                <p class="text-center mb-0">
                    Déjà un compte ? <a href="/compte/connexion">Se connecter</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private ModeleInscription? Modele { get; set; }

    private List<string> _erreurs = new();

    protected override void OnInitialized() => Modele ??= new();

    private async Task SInscrire()
    {
        _erreurs.Clear();

        if (!string.IsNullOrEmpty(Configuration["Beta:CodeInvitation"]))
        {
            var codeAttendu = Configuration["Beta:CodeInvitation"] ?? "";
            if (!string.Equals(Modele!.CodeInvitation?.Trim(), codeAttendu, StringComparison.Ordinal))
            {
                _erreurs.Add("Code d'invitation invalide.");
                return;
            }
        }

        if (Modele!.MotDePasse != Modele.Confirmation)
        {
            _erreurs.Add("Les mots de passe ne correspondent pas.");
            return;
        }

        var utilisateur = new ApplicationUser
        {
            UserName = Modele.Email,
            Email = Modele.Email,
            DisplayName = Modele.NomAffichage
        };

        var resultat = await UserManager.CreateAsync(utilisateur, Modele.MotDePasse);

        if (resultat.Succeeded)
        {
            await SignInManager.SignInAsync(utilisateur, isPersistent: false);
            Navigation.NavigateTo("/");
        }
        else
        {
            _erreurs = resultat.Errors.Select(e => e.Description).ToList();
        }
    }

    private class ModeleInscription
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Le nom d'affichage est obligatoire.")]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string NomAffichage { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "L'email est obligatoire.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Email invalide.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Le mot de passe est obligatoire.")]
        [System.ComponentModel.DataAnnotations.MinLength(6, ErrorMessage = "Minimum 6 caractères.")]
        public string MotDePasse { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "La confirmation est obligatoire.")]
        public string Confirmation { get; set; } = string.Empty;

        public string? CodeInvitation { get; set; }
    }
}
