@using Microsoft.AspNetCore.Components.Forms

<div>
    <InputFile OnChange="OnFichierChoisi" accept="image/*" class="form-control form-control-sm" />
    @if (!string.IsNullOrEmpty(_messageErreur))
    {
        <div class="text-danger small mt-1">@_messageErreur</div>
    }
</div>

@code {
    [Parameter] public EventCallback<(string Base64, string TypeMime)> OnPhotoChoisie { get; set; }
    [Parameter] public string LibelleBtn { get; set; } = "Choisir une image";

    private string? _messageErreur;

    // Taille max : 5 Mo
    private const long TailleMaxOctets = 5 * 1024 * 1024;

    private async Task OnFichierChoisi(InputFileChangeEventArgs e)
    {
        _messageErreur = null;
        var fichier = e.File;

        if (fichier.Size > TailleMaxOctets)
        {
            _messageErreur = "L'image ne doit pas dépasser 5 Mo.";
            return;
        }

        if (!fichier.ContentType.StartsWith("image/"))
        {
            _messageErreur = "Veuillez sélectionner un fichier image.";
            return;
        }

        try
        {
            using var flux = fichier.OpenReadStream(TailleMaxOctets);
            using var ms = new MemoryStream();
            await flux.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            await OnPhotoChoisie.InvokeAsync((base64, fichier.ContentType));
        }
        catch (Exception ex)
        {
            _messageErreur = $"Erreur lors de la lecture du fichier : {ex.Message}";
        }
    }
}
