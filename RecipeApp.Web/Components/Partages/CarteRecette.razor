@using RecipeApp.Application.DTOs
@using RecipeApp.Domain.Enums

<div class="card h-100 shadow-sm">
    @if (!string.IsNullOrEmpty(Recette.CheminImage))
    {
        <img src="@Recette.CheminImage" class="card-img-top" alt="@Recette.Titre" style="height:180px;object-fit:cover;" />
    }
    else
    {
        <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height:180px;">
            <span class="display-4 text-muted">🍽️</span>
        </div>
    }
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">
            <a href="/recettes/@Recette.Id" class="text-decoration-none text-dark">@Recette.Titre</a>
        </h5>
        @if (!string.IsNullOrEmpty(Recette.Description))
        {
            <p class="card-text text-muted small">
                @(Recette.Description.Length > 80 ? Recette.Description[..80] + "…" : Recette.Description)
            </p>
        }
        <div class="mt-auto">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-muted">
                    ⏱️ @(Recette.TempsPreparation + Recette.TempsCuisson) min
                    &bull; @Recette.NombrePortions portion(s)
                </small>
                <span class="badge @BadgeDifficulte(Recette.Difficulte)">@Recette.Difficulte</span>
            </div>
            @if (Recette.Etiquettes.Any())
            {
                <div>
                    @foreach (var etiq in Recette.Etiquettes.Take(3))
                    {
                        <span class="badge bg-secondary me-1 mb-1 small">@etiq.Nom</span>
                    }
                </div>
            }
            @if (AfficherActions)
            {
                <div class="d-flex gap-2 mt-2">
                    <a href="/recettes/@Recette.Id/modifier" class="btn btn-sm btn-outline-secondary flex-fill">Modifier</a>
                    <button class="btn btn-sm btn-outline-danger flex-fill" @onclick="() => OnSuppression.InvokeAsync()">Supprimer</button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public RecetteDto Recette { get; set; } = null!;
    [Parameter] public bool AfficherActions { get; set; }
    [Parameter] public EventCallback OnSuppression { get; set; }

    private static string BadgeDifficulte(Difficulte d) => d switch
    {
        Difficulte.Facile => "bg-success",
        Difficulte.Moyen => "bg-warning text-dark",
        Difficulte.Difficile => "bg-danger",
        _ => "bg-secondary"
    };
}
